# Copy to .env.local and fill in values from Supabase Dashboard → Project Settings → API / Database

# Supabase (Dashboard → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Publishable key (recommended) or legacy anon JWT
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Legacy alias if your code uses it:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only — never expose to the browser or NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# Private Storage bucket for GDPR/DSR ZIP exports (create in Supabase Dashboard → Storage; default name below).
# COMPLIANCE_EXPORTS_BUCKET=compliance-exports

# Postgres connection (Dashboard → Database → Connection pooling → Transaction pooler URI)
# pgbouncer=true is required for postgres.js / Drizzle on port 6543; without it you can hit “max client connections”.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true
# Optional: postgres.js pool size per Node process (default 1). Raise only after confirming pooler URL above.
# DATABASE_POOL_MAX=1

# When true, /student/practice shows step 4 (user JSON + system prompt preview). Omit or false in production.
PRACTICE_PROMPT_PREVIEW=false
# When true, log aggregate topic_context chunk stats per generation (no raw chunk text). Default: off in prod and dev.
# PRACTICE_TOPIC_CONTEXT_LOG=true
# Optional caps for topic_context_chunks size (integers; invalid values fall back to built-in defaults).
# PRACTICE_TOPIC_CONTEXT_MAX_CONTEXT_CHUNKS_PER_TOPIC=12
# PRACTICE_TOPIC_CONTEXT_MAX_EXERCISE_CHUNKS_PER_TOPIC=10
# PRACTICE_TOPIC_CONTEXT_MAX_CONTEXT_CHARS_PER_TOPIC=4000
# PRACTICE_TOPIC_CONTEXT_MAX_EXERCISE_CHARS_PER_TOPIC=3500
# PRACTICE_TOPIC_CONTEXT_MAX_TOTAL_CONTEXT_CHARS=22000
# PRACTICE_TOPIC_CONTEXT_MAX_TOTAL_EXERCISE_CHARS=16000

# App URL for Auth redirects (must match Supabase Auth → URL Configuration)
NEXT_PUBLIC_APP_URL=http://localhost:3001
# When true, non-production API routes may authenticate via Authorization Bearer/Basic (tests only; never enable on public staging).
# ALLOW_API_HEADER_AUTH=true
# Optional — shown on /legal/* pages for billing and privacy inquiries (safe to expose publicly)
# NEXT_PUBLIC_SUPPORT_EMAIL=support@yourdomain.com
# Password recovery: add these to Supabase → Authentication → URL Configuration → Redirect URLs:
#   http://localhost:3001/auth/callback
#   https://YOUR_PRODUCTION_DOMAIN/auth/callback
#
# Auth email (Dashboard → Authentication → Email):
# - Enable "Confirm email" if you want verified signups before RPC registration.
# - Customize "Reset password" template; reset link must point to your app route that calls
#   supabase.auth.exchangeCodeForSession or handles the hash fragment (see Supabase Auth docs).
# - Enable "Leaked password protection" (Have I Been Pwned) under Password settings.

# Resend (https://resend.com) — required when students change guardian email on /student/settings
RESEND_API_KEY=re_...
# Verified sender (domain must be verified in Resend). Name + email or email only.
RESEND_FROM_EMAIL="EduAI <notifications@yourdomain.com>"
# Optional alias (same value) if you prefer the older name:
# RESEND_FROM="EduAI <notifications@yourdomain.com>"
# Webhook signing secret for POST /api/webhooks/resend (delivery/open/click → email_log).
# Use the Resend endpoint signing secret from the dashboard (starts with whsec_). Dev-only: Bearer or ?token= with any shared secret if you are not using Svix headers.
# RESEND_WEBHOOK_SECRET=whsec_...

# OpenAI (https://platform.openai.com) — server-only; `@ai-sdk/openai` + Vercel AI SDK
OPENAI_API_KEY=sk-...
# Optional; default is gpt-5.4-mini (ChatGPT 5.4 mini class)
# OPENAI_CHAT_MODEL=gpt-5.4-mini

# Sentry (https://sentry.io) — optional; omit all SENTRY_* / NEXT_PUBLIC_SENTRY_* vars to disable the SDK.
# Project → Settings → Client Keys (DSN). Client init runs only when NEXT_PUBLIC_SENTRY_DSN is set.
# NEXT_PUBLIC_SENTRY_DSN=https://YOUR_KEY@YOUR_ORG.ingest.de.sentry.io/YOUR_PROJECT_ID
# Server and edge use SENTRY_DSN first, then fall back to NEXT_PUBLIC_SENTRY_DSN (sentry.server.config.ts / sentry.edge.config.ts).
# SENTRY_DSN=https://YOUR_KEY@YOUR_ORG.ingest.de.sentry.io/YOUR_PROJECT_ID
# Trace sample rates (0.0–1.0). Sensible defaults exist if unset; tune for prod vs dev.
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_TRACES_SAMPLE_RATE=0.2
# Optional server profiling sample rate (0 disables).
# SENTRY_PROFILES_SAMPLE_RATE=0

# Next dev on macOS: avoids Watchpack EMFILE / flaky HMR (see scripts/next-dev.mjs). Set to 1 only if you raised NOFILE and want native fs.watch.
# NEXT_DEV_NATIVE_FS_WATCH=1
# Next 16 Turbopack: if dev crashes with missing `.next/dev/server/chunks/ssr/[turbopack]_runtime.js`, run `pnpm dev:clean` first, or force webpack: `pnpm dev:webpack` / NEXT_DEV_WEBPACK=1.
# NEXT_DEV_WEBPACK=1

# Practice tests: grade in the submit request instead of the background worker (local debugging).
# PRACTICE_SYNC_GRADING=true
# Protects /api/internal/* worker routes. Required in production and for `next dev` when
# NEXT_PUBLIC_APP_URL is a LAN IP/hostname (post-submit worker uses this URL). Pure localhost dev may omit.
# CRON_SECRET=
# Supabase pg_cron (Vault `cron_secret` + `app_base_url`) calls internal routes with `Authorization: Bearer …`.
# Example: weekly digest Mondays 03:30 UTC — see `supabase/migrations/20260516100000_internal_http_routes_pg_cron.sql`.

# =====================================================================
# Razorpay Subscriptions (https://dashboard.razorpay.com)
# Test keys during development; swap to live keys in production.
# Dashboard → Settings → API Keys; Webhooks under Settings → Webhooks.
#
# After keys work: run `pnpm razorpay:seed-plans`, then set `plans.razorpay_plan_id` in Supabase for
# `pro_monthly` and `pro_annual`. Register webhook POST URL `https://<your-domain>/api/billing/webhook`
# with the same secret as RAZORPAY_WEBHOOK_SECRET.
# =====================================================================
RAZORPAY_KEY_ID=rzp_test_...
# Server-only secret — never expose to the browser or NEXT_PUBLIC_
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Random shared secret you configure on the webhook in Razorpay Dashboard
RAZORPAY_WEBHOOK_SECRET=a_long_random_string
# Optional comma-separated extra signing secrets (local/staging test harnesses only). Never use guessable values on public URLs.
# RAZORPAY_WEBHOOK_SECRET_EXTRA=other_secret_from_test_fixture
# Public (client-side) key id for Razorpay Checkout; must match the server key (test or live)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...

# Hard gate for SaaS quota enforcement. Keep OFF in local dev, ON in production.
# When false, getEntitlements still calculates usage meters but never blocks an action.
SAAS_ENFORCEMENT=false

# =====================================================================
# Operator admin panel (Phase 1) — copy block into .env.local
# =====================================================================
#
# Before copying:
# - Precedence: ADMIN_PASSWORD_HASH_B64 (bcrypt, recommended) → ADMIN_PASSWORD (plain) → ADMIN_PASSWORD_HASH (legacy).
#   When ADMIN_PASSWORD_HASH_B64 is set, plain and legacy hash are ignored.
# - ADMIN_PASSWORD_HASH_B64 (recommended for prod) — base64(utf8(bcrypt_hash)). No `$` in .env value. Generate:
#     From repo root after `pnpm install`: `pnpm run admin:password-hash-b64 -- 'YOUR_STRONG_PASSWORD'` (prints one line for ADMIN_PASSWORD_HASH_B64). Or: `node -e "const b=require('bcryptjs');..."` only works if `node_modules/bcryptjs` exists (same folder as package.json).
# - ADMIN_PASSWORD — plain text (local/dev only if you omit B64). Wrap in single quotes if it contains `#` or spaces.
# - ADMIN_PASSWORD_HASH (optional legacy) — bcrypt string only if both B64 and plain are unset. In production, bcrypt work factor must be ≥ 12 (§10.6). Next.js dotenv-expand breaks raw `$` in hashes — prefer `ADMIN_PASSWORD_HASH_B64`, or escape each `$` as `\$`.
# - ADMIN_JWT_SECRET — random 32+ byte hex string, e.g.:
#     openssl rand -hex 32
# - ADMIN_PANIC_TOKEN (optional) — random hex for GET /api/admin/panic?token=...
#     openssl rand -hex 16
# - ADMIN_TOTP_SECRET (optional) — base32 secret from your authenticator app when enabling 2FA.
# - ADMIN_IP_ALLOWLIST (optional) — comma-separated exact IPs (no CIDR in Phase 1), e.g. 203.0.113.10,198.51.100.2
#   Local `next start` often has no X-Forwarded-For → client IP `0.0.0.0`, which will not match your public IP. Fix: use `pnpm dev`, add `0.0.0.0` to the list for local-only testing, or set ADMIN_LOGIN_ALLOW_UNKNOWN_IP=1 (trusted local/staging only).
# - ADMIN_LOGIN_ALLOW_UNKNOWN_IP (optional) — set to 1 with ADMIN_IP_ALLOWLIST when the server cannot see a real client IP (e.g. bare `next start`). Never use on public production without a reverse proxy you trust.
#   In non-production, unknown client IP (no X-Forwarded-For on local next dev) and loopback are allowed so admin login still works.
# - JWT version + login rate limits use Postgres tables `admin_runtime_kv` and `admin_login_rate` (Supabase migration).
# - MAINTENANCE_MODE — set to true to send non-admin traffic to /maintenance (admin routes still work).
# - ADMIN_SQL_WRITE_ENABLED — default false; when true, SQL console may run INSERT/UPDATE/DELETE on allowlisted tables only.
# - ADMIN_SQL_WRITE_ALLOWLIST_TABLES — comma-separated Postgres table names (lowercase), e.g. profiles (required when write is enabled).
# - ADMIN_INTEGRATION_TESTS — set true with real DATABASE_URL + Supabase to run admin Vitest integration tests.
# - CI: `.github/workflows/admin-panel.yml` runs `pnpm run build` + a client-bundle leak check when these repo
#   secrets are set: NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY, SUPABASE_SERVICE_ROLE_KEY.
#   Optional: DATABASE_URL (otherwise the workflow uses a dummy URL so the build can compile).
#
# Playwright (optional): `pnpm run test:e2e` — see docs/admin-panel-verification.md
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3001
# Prefer 127.0.0.1 over localhost so API + browser both hit IPv4 (avoids ::1 ECONNREFUSED).
# PLAYWRIGHT_START_WEBSERVER=1  # optional: let Playwright run `pnpm run dev` (needs working DATABASE_URL)
# PLAYWRIGHT_ADMIN_EMAIL= (same as ADMIN_EMAIL)
# PLAYWRIGHT_ADMIN_PASSWORD= (plain password for operator)
# PLAYWRIGHT_ADMIN_TOTP= (optional 6-digit code when ADMIN_TOTP_REQUIRED is on)
# PLAYWRIGHT_E2E_TARGET_USER_ID= (uuid — student recommended for L2 user-360 browser tests)
# PLAYWRIGHT_PANIC_TOKEN= (optional — same value as ADMIN_PANIC_TOKEN for E2E that calls GET /api/admin/panic; revokes the logged-in session)
#
# --- BEGIN COPY TO .env.local (fill every line you use; leave optional lines blank or delete) ---
ADMIN_EMAIL=
# Recommended prod: set ADMIN_PASSWORD_HASH_B64 and leave ADMIN_PASSWORD empty. See precedence note above.
ADMIN_PASSWORD_HASH_B64=
ADMIN_PASSWORD=
# Legacy bcrypt string (omit if using B64). Escape `$` as `\$` for Next, or use B64 only.
ADMIN_PASSWORD_HASH=''
ADMIN_JWT_SECRET=
ADMIN_TOTP_SECRET=
ADMIN_PANIC_TOKEN=
ADMIN_IP_ALLOWLIST=
# ADMIN_LOGIN_ALLOW_UNKNOWN_IP=1
MAINTENANCE_MODE=false
ADMIN_INTEGRATION_TESTS=false
# --- END COPY ---

# =====================================================================
# Phase 8 — Operator jobs (Postgres queue + internal routes)
# =====================================================================
#
# Queued rows in `public.jobs` are drained by GET/POST `/api/internal/admin/process-operator-jobs`
# (same `CRON_SECRET` Bearer pattern as `/api/internal/practice/run-jobs`).
#
# **Scheduling (standard):** Supabase `pg_cron` + `pg_net` → your production app URL. See migration
# `supabase/migrations/20260516100000_internal_http_routes_pg_cron.sql` (and practice jobs migration for the pattern).
# **Supabase Vault** must define `app_base_url` (no trailing slash) and `cron_secret` (same value as `CRON_SECRET` here).
#
# Optional: `NEXT_PUBLIC_APP_URL` / app URL so admin-triggered jobs can `fetch` the internal route after enqueue.
# If that `fetch` fails, bulk re-init falls back to inline execution in the Next process.
