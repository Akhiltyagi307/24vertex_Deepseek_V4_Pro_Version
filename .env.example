# =============================================================================
# 24Vertex — local environment (.env.local)
# =============================================================================
# Copy from this file for local dev. Never commit real secrets to git.
#
# Legend:
#   (required) — app or feature breaks without it in the paths that need it
#   (optional) — has a safe default or feature degrades gracefully when unset
#
# Vercel: set keys marked "Deploy: yes" in Preview/Production. Skip Playwright
# and plain ADMIN_PASSWORD on Vercel.
# =============================================================================


# =============================================================================
# 1) Public app config (NEXT_PUBLIC_*)
# Deploy: yes — safe to expose in the browser
# =============================================================================

# (required) Supabase project URL (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# (required) Supabase publishable key (replaces legacy anon JWT)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# (required in production) Canonical site URL for links, auth cookies, SEO.
# Local dev: match `pnpm dev` (see scripts/next-dev.mjs). Prefer 127.0.0.1 over
# localhost if you mix URLs — split cookie jars otherwise.
NEXT_PUBLIC_APP_URL=http://localhost:3001

# (optional) Support address shown on /contact, legal, and marketing pages
NEXT_PUBLIC_SUPPORT_EMAIL=hello@yourdomain.example.com

# (optional) Client-side practice generation streaming (wizard uses SSE when true)
NEXT_PUBLIC_PRACTICE_STREAM=false

# (optional) Razorpay Checkout key id — must match RAZORPAY_KEY_ID
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXX

# (optional) Sentry DSN for client-side error reporting (leave empty to disable)
NEXT_PUBLIC_SENTRY_DSN=

# (optional) Registered entity block on /contact and /about
# NEXT_PUBLIC_LEGAL_ENTITY_NAME=
# NEXT_PUBLIC_REGISTERED_ADDRESS=


# =============================================================================
# 2) Supabase & database (server-only)
# Deploy: yes
# =============================================================================

# (required) Service role key — bypasses RLS; admin user creation, workers, scripts.
# Dashboard → Settings → API. Never expose as NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME

# (required) Postgres connection — use Supabase transaction pooler (:6543, pgbouncer=true)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true

# (optional) Max connections per Node process (default 5, capped at 10). Use 1 on serverless.
DATABASE_POOL_MAX=1

# (optional) Separate pool for rate-limit RPCs (falls back to DATABASE_URL)
# DATABASE_RATELIMIT_URL=
# DATABASE_RATELIMIT_POOL_MAX=3

# (optional) Supabase storage bucket for GDPR export ZIPs (default: compliance-exports)
# COMPLIANCE_EXPORTS_BUCKET=compliance-exports


# =============================================================================
# 3) Email & notifications (server-only)
# Deploy: yes (when sending mail)
# =============================================================================

# (required for email) Resend API key
RESEND_API_KEY=re_REPLACE_ME

# (required for email) Verified sender, e.g. "ExamPrep AI <noreply@yourdomain.com>"
RESEND_FROM_EMAIL="ExamPrep AI <noreply@example.com>"

# (optional) Signs List-Unsubscribe headers; min 32 chars. Skips header when unset.
EMAIL_UNSUBSCRIBE_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET

# (optional) Inbox for /contact-form notifications. Falls back to NEXT_PUBLIC_SUPPORT_EMAIL.
CONTACT_NOTIFICATION_EMAIL=

# (optional) Resend webhook signing secret (Svix) for bounce/complaint events
# RESEND_WEBHOOK_SECRET=

# (optional) Admin panic/digest recipients (comma-separated). Falls back to ADMIN_EMAIL.
# ADMIN_NOTIFICATION_EMAILS=

# (optional) Email template logo overrides
# EMAIL_LOGO_URL=
# EMAIL_LOGO_EMBED=1


# =============================================================================
# 4) OpenAI (server-only)
# Deploy: yes
# =============================================================================

# (required) OpenAI API key — chat, fallbacks, embeddings, moderation
OPENAI_API_KEY=sk-proj-REPLACE_ME

# (required in production) Default chat model
OPENAI_CHAT_MODEL=gpt-5.4-mini

# (optional) Doubt chat model — falls back to OPENAI_CHAT_MODEL
OPENAI_DOUBT_CHAT_MODEL=gpt-5.4-mini

# (optional) Practice generation / repair / visual validator — falls back to OPENAI_CHAT_MODEL
OPENAI_PRACTICE_CHAT_MODEL=gpt-5.4-mini

# (optional) Primary model 429/timeout fallback
OPENAI_CHAT_MODEL_FALLBACK=gpt-5.4-mini

# (optional) Practice-specific fallback — falls back to OPENAI_CHAT_MODEL_FALLBACK
# OPENAI_PRACTICE_CHAT_MODEL_FALLBACK=


# =============================================================================
# 5) DeepSeek & AI provider routing (server-only)
# Deploy: yes (when routing features to DeepSeek)
# =============================================================================

# (required when AI_PROVIDER_*=deepseek) DeepSeek API key
DEEPSEEK_API_KEY=sk-REPLACE_ME

# (optional) Default DeepSeek chat model (default: deepseek-v4-pro)
DEEPSEEK_CHAT_MODEL=deepseek-v4-flash

# (optional) Per-feature model overrides — Flash for structural, Pro for content
DEEPSEEK_DOUBT_CHAT_MODEL=deepseek-v4-flash
DEEPSEEK_BLUEPRINT_MODEL=deepseek-v4-flash
DEEPSEEK_VISUAL_ENRICHMENT_MODEL=deepseek-v4-flash
DEEPSEEK_GRADE_SUMMARY_MODEL=deepseek-v4-flash

# (optional) Reasoning effort: low | medium | high | xhigh | max (default: medium)
DEEPSEEK_REASONING_EFFORT=medium

# (optional) Per-pass thinking: enabled | disabled | adaptive
DEEPSEEK_BLUEPRINT_THINKING=disabled
DEEPSEEK_VISUAL_ENRICHMENT_THINKING=enabled
DEEPSEEK_GRADE_SUMMARY_THINKING=disabled

# (optional) Self-hosted gateway base URL (default: https://api.deepseek.com)
# DEEPSEEK_BASE_URL=

# (optional) Default provider when per-feature override unset (openai | deepseek)
AI_PROVIDER_DEFAULT=deepseek

# Per-feature provider overrides (openai | deepseek). Unset → AI_PROVIDER_DEFAULT → openai.
AI_PROVIDER_DOUBT_CHAT=deepseek
AI_PROVIDER_PRACTICE_GENERATION=deepseek
AI_PROVIDER_PRACTICE_GENERATION_BLUEPRINT=deepseek
AI_PROVIDER_PRACTICE_GENERATION_REPAIR=deepseek
AI_PROVIDER_PRACTICE_GENERATION_VISUAL_ENRICHMENT=deepseek
AI_PROVIDER_PRACTICE_GRADE_CHUNK=deepseek
AI_PROVIDER_PRACTICE_GRADE_SUMMARY=deepseek

# (optional) USD→INR for AI cost telemetry (default in code)
# AI_COST_USD_TO_INR=90


# =============================================================================
# 6) Practice generation — core behavior
# Deploy: yes
# =============================================================================

# (optional) Pipeline: 5call (default) | 3call — 3call skips retry rounds, single visual enrich
PRACTICE_PIPELINE_VARIANT=3call

# (optional) Split main generation into parallel MCQ/FIB/SA/LA batches (default: false)
PRACTICE_PARALLEL_BATCHES=true

# (optional) Force LLM blueprint in 3call variant (default: false)
# PRACTICE_BLUEPRINT_LLM=true
PRACTICE_BLUEPRINT_LLM=true
# (optional) true = block until grading finishes; false = async job queue (recommended)
PRACTICE_SYNC_GRADING=false

# (optional) Server SSE route /api/student/practice/generate-stream (non-prod defaults on)
PRACTICE_STREAM=false

# (optional) Within-test adaptive difficulty follow-ups
PRACTICE_ADAPTIVE=true

# (optional) Dev-only: show system prompt + user JSON in practice wizard step 4
PRACTICE_PROMPT_PREVIEW=false

# (optional) Max questions graded in parallel per worker invocation (default: 3)
# PRACTICE_WORKER_CONCURRENCY=3

# (optional) Strict JSON schema toggles (generate on by default; repair/grade off unless set)
# PRACTICE_STRICT_JSON_SCHEMA_GENERATE=true
# PRACTICE_STRICT_JSON_SCHEMA_REPAIR=false
# PRACTICE_STRICT_JSON_SCHEMA_GRADE=false

# (optional) Repair behavior
# PRACTICE_GENERATION_REPAIR=true
# PRACTICE_REPAIR_INCLUDE_FULL_CONTEXT=false
# PRACTICE_GENERATION_REPAIR_BUDGET=3


# =============================================================================
# 7) Practice visuals
# Deploy: yes
# =============================================================================

# (optional) Master switch — structured `visual` field on generated questions
PRACTICE_VISUALS=true

# (optional) Typed subject/topic template registry for visual kinds
PRACTICE_VISUAL_TEMPLATE_ENGINE=true

# (optional) Pass-2 OpenAI skills validator (best-effort polish)
PRACTICE_VISUAL_VALIDATOR=true

# (optional) Validator model — falls back to OPENAI_PRACTICE_CHAT_MODEL
PRACTICE_VISUAL_VALIDATOR_MODEL=gpt-5.4-mini

# (optional) Dedicated visual enrichment pass (defaults to PRACTICE_VISUALS when unset)
PRACTICE_VISUAL_ENRICHMENT=true

# (optional) Candidates per enrichment request (1–30, default 2)
PRACTICE_VISUAL_ENRICHMENT_BATCH_SIZE=12

# (optional) Stem↔visual grounding: off | shadow | enforce
PRACTICE_VISUAL_STEM_GROUNDING=shadow

# (optional) Few-shot exemplar count in system prompt (3–12, default 8)
PRACTICE_VISUAL_EXEMPLAR_COUNT=12

# (optional) Lexical alignment gate when context_quality is ok/low (default: true)
PRACTICE_CHUNK_ALIGN_LEXICAL=true

# (optional) Pass threshold for `pnpm eval:visuals` (default 0.9)
PRACTICE_VISUALS_EVAL_THRESHOLD=0.9

# (optional) CSV subject allowlist, e.g. Mathematics,Accountancy
# PRACTICE_VISUALS_SUBJECTS=

# (optional) Enrichment model override
# PRACTICE_VISUAL_ENRICHMENT_MODEL=

# (optional) OpenAI skill map JSON for validator pass
# PRACTICE_OPENAI_SKILL_MAP=


# =============================================================================
# 8) Practice topic context (telemetry)
# Deploy: optional
# =============================================================================

# (optional) Log aggregate topic-context stats (no raw chunk text). All fetched chunks are included in prompts.
PRACTICE_TOPIC_CONTEXT_LOG=true


# =============================================================================
# 9) Internal routes, workers & SaaS (server-only)
# Deploy: yes (CRON_SECRET in production)
# =============================================================================

# (required in production) Bearer token for /api/internal/* (trial emails, practice workers).
# Generate: openssl rand -hex 32. Unset allowed on loopback only.
CRON_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET

# (optional) Enforce subscription quotas (keep false in dev to avoid locking seed users)
SAAS_ENFORCEMENT=false

# (optional) Send non-admin traffic to /maintenance (admin routes still work)
MAINTENANCE_MODE=false


# =============================================================================
# 10) Observability (Sentry)
# Deploy: yes (optional — leave empty to disable)
# =============================================================================

# (optional) Server-side Sentry DSN (falls back to NEXT_PUBLIC_SENTRY_DSN)
SENTRY_DSN=

# (optional) Trace/profile sampling overrides
# SENTRY_TRACES_SAMPLE_RATE=0.02
# SENTRY_PROFILES_SAMPLE_RATE=0

# (optional) Admin feedback page deep-links to Sentry issues
# SENTRY_ORG_SLUG=
# SENTRY_PROJECT_SLUG=


# =============================================================================
# 11) Admin panel (server-only)
# Deploy: yes — use ADMIN_PASSWORD_HASH_B64 in production, not plain password
# =============================================================================

# (required) Admin login email (also fallback notification recipient)
ADMIN_EMAIL=admin@example.com

# (required locally) Plain password — dev only. Production: ADMIN_PASSWORD_HASH_B64.
ADMIN_PASSWORD=CHANGE_ME_LOCAL_ONLY

# (required) JWT signing secret — openssl rand -hex 32
ADMIN_JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET

# (optional) TOTP secret (authenticator app). Required when ADMIN_TOTP_REQUIRED flag is on in DB.
ADMIN_TOTP_SECRET=REPLACE_ME_BASE32

# (optional) Panic endpoint token — GET /api/admin/panic?token=...
ADMIN_PANIC_TOKEN=REPLACE_WITH_RANDOM_TOKEN

# (optional) Run admin Vitest integration tests against real DATABASE_URL
ADMIN_INTEGRATION_TESTS=false

# (optional) Production bcrypt hash (base64) — takes precedence over ADMIN_PASSWORD
# ADMIN_PASSWORD_HASH_B64=

# (optional) Legacy bcrypt hash (prefer _B64 in production)
# ADMIN_PASSWORD_HASH=

# (optional) JWT kid rotation secrets for panic flow — ADMIN_JWT_SECRET_v1, _v2, …
# ADMIN_JWT_SECRET_v1=

# (optional) Admin SQL console write mode (requires ADMIN_TOTP_SECRET)
# ADMIN_SQL_WRITE_ENABLED=false
# ADMIN_SQL_WRITE_ALLOWLIST_TABLES=
# ADMIN_SQL_MAX_PLAN_COST=100000

# (optional) Allow Razorpay force-renew from admin without extra guard
# ADMIN_BILLING_FORCE_RENEW_RZP=1

# (optional) IP allowlist for admin login (comma-separated). See src/lib/admin/ip-allowlist.ts
# ADMIN_IP_ALLOWLIST=
# ADMIN_LOGIN_ALLOW_UNKNOWN_IP=1

# (optional) Production CSP — drop unsafe-inline on portal routes when 1
# PRODUCTION_DROP_UNSAFE_INLINE_SCRIPT_FALLBACK=1


# =============================================================================
# 12) Payments — Razorpay
# Deploy: yes (test keys in Preview; live keys in Production)
# =============================================================================

# (required for billing) Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET_FROM_RAZORPAY

# (required for webhooks) Must match Razorpay Dashboard → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING

# (optional) Extra webhook secrets during rotation (comma-separated)
# RAZORPAY_WEBHOOK_SECRET_EXTRA=


# =============================================================================
# 13) Playwright E2E (local / CI only — do not deploy to Vercel)
# =============================================================================

# (optional) Base URL — defaults to NEXT_PUBLIC_APP_URL. Match `pnpm dev` host/port.
PLAYWRIGHT_BASE_URL=http://localhost:3001

# (required for admin E2E) Admin panel smoke / admin-panel.spec.ts
PLAYWRIGHT_ADMIN_EMAIL=admin@example.com
PLAYWRIGHT_ADMIN_PASSWORD=CHANGE_ME_LOCAL_ONLY
PLAYWRIGHT_E2E_TARGET_USER_ID=00000000-0000-0000-0000-000000000000

# (optional) Generic student user — auth.setup, practice E2E, smoke
PLAYWRIGHT_USER_EMAIL=user@example.com
PLAYWRIGHT_USER_PASSWORD=CHANGE_ME_LOCAL_ONLY

# (optional) Role-specific E2E — tests skip when unset
# PLAYWRIGHT_STUDENT_EMAIL=
# PLAYWRIGHT_STUDENT_PASSWORD=
# PLAYWRIGHT_STUDENT_USER_ID=
# PLAYWRIGHT_PARENT_EMAIL=
# PLAYWRIGHT_PARENT_PASSWORD=
# PLAYWRIGHT_TEACHER_EMAIL=
# PLAYWRIGHT_TEACHER_PASSWORD=

# (optional) Admin panic E2E — admin-panic.spec.ts
# PLAYWRIGHT_PANIC_TOKEN=
# PLAYWRIGHT_ADMIN_TOTP_SECRET=
# PLAYWRIGHT_ADMIN_TOTP=

# (optional) Practice full-subjects E2E tuning
# PLAYWRIGHT_PRACTICE_E2E_SUBJECT_CAP=
# PLAYWRIGHT_PRACTICE_E2E_MAX_SLOTS=32
# PLAYWRIGHT_START_WEBSERVER=1

# (optional) DeepSeek timing E2E subset
# DEEPSEEK_TIMING_SUBJECT_CAP=
