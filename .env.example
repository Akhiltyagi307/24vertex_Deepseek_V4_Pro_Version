# Copy to .env.local and fill in values from Supabase Dashboard → Project Settings → API / Database

# Supabase (Dashboard → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Publishable key (recommended) or legacy anon JWT
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Legacy alias if your code uses it:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only — never expose to the browser or NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# Postgres connection (Dashboard → Database → Connection string → URI; use pooler for serverless)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require

# When true, /student/practice shows step 4 (user JSON + system prompt preview). Omit or false in production.
PRACTICE_PROMPT_PREVIEW=false
# When true, log aggregate topic_context chunk stats per generation (no raw chunk text). Default: off in prod and dev.
# PRACTICE_TOPIC_CONTEXT_LOG=true
# Optional caps for topic_context_chunks size (integers; invalid values fall back to built-in defaults).
# PRACTICE_TOPIC_CONTEXT_MAX_CONTEXT_CHUNKS_PER_TOPIC=12
# PRACTICE_TOPIC_CONTEXT_MAX_EXERCISE_CHUNKS_PER_TOPIC=10
# PRACTICE_TOPIC_CONTEXT_MAX_CONTEXT_CHARS_PER_TOPIC=4000
# PRACTICE_TOPIC_CONTEXT_MAX_EXERCISE_CHARS_PER_TOPIC=3500
# PRACTICE_TOPIC_CONTEXT_MAX_TOTAL_CONTEXT_CHARS=22000
# PRACTICE_TOPIC_CONTEXT_MAX_TOTAL_EXERCISE_CHARS=16000

# App URL for Auth redirects (must match Supabase Auth → URL Configuration)
NEXT_PUBLIC_APP_URL=http://localhost:3001
# Password recovery: add these to Supabase → Authentication → URL Configuration → Redirect URLs:
#   http://localhost:3001/auth/callback
#   https://YOUR_PRODUCTION_DOMAIN/auth/callback
#
# Auth email (Dashboard → Authentication → Email):
# - Enable "Confirm email" if you want verified signups before RPC registration.
# - Customize "Reset password" template; reset link must point to your app route that calls
#   supabase.auth.exchangeCodeForSession or handles the hash fragment (see Supabase Auth docs).
# - Enable "Leaked password protection" (Have I Been Pwned) under Password settings.

# Resend (https://resend.com) — required when students change guardian email on /student/settings
RESEND_API_KEY=re_...
# Verified sender (domain must be verified in Resend). Name + email or email only.
RESEND_FROM_EMAIL="EduAI <notifications@yourdomain.com>"
# Optional alias (same value) if you prefer the older name:
# RESEND_FROM="EduAI <notifications@yourdomain.com>"

# OpenAI (https://platform.openai.com) — server-only; `@ai-sdk/openai` + Vercel AI SDK
OPENAI_API_KEY=sk-...
# Optional; default is gpt-5.4-mini (ChatGPT 5.4 mini class)
# OPENAI_CHAT_MODEL=gpt-5.4-mini

# Practice tests: grade in the submit request instead of the background worker (local debugging).
# PRACTICE_SYNC_GRADING=true
# Protects /api/internal/practice/* cron routes. Required in production. In local `next dev` off Vercel,
# omit so the post-submit grader trigger works; on Vercel (preview or prod) set the same value Vercel Cron uses.
# CRON_SECRET=

# =====================================================================
# Razorpay Subscriptions (https://dashboard.razorpay.com)
# Test keys during development; swap to live keys in production.
# Dashboard → Settings → API Keys; Webhooks under Settings → Webhooks.
# =====================================================================
RAZORPAY_KEY_ID=rzp_test_...
# Server-only secret — never expose to the browser or NEXT_PUBLIC_
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Random shared secret you configure on the webhook in Razorpay Dashboard
RAZORPAY_WEBHOOK_SECRET=a_long_random_string
# Public (client-side) key id for Razorpay Checkout; must match the server key
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...

# Hard gate for SaaS quota enforcement. Keep OFF in local dev, ON in production.
# When false, getEntitlements still calculates usage meters but never blocks an action.
SAAS_ENFORCEMENT=false
