# =============================================================================
# EduAI environment template
# =============================================================================
# Source baseline: current .env.local
#
# How to use:
# 1) Copy this file to `.env.local` for local development.
# 2) For Vercel, add only the keys marked "Deploy (Vercel): yes".
# 3) Never commit real secrets.
#
# Legend:
# - Deploy (Vercel): yes   -> set in Preview/Production environments.
# - Deploy (Vercel): no    -> local/dev-only key; do not set in Vercel.
# =============================================================================

# -----------------------------------------------------------------------------
# 1) Public runtime config (NEXT_PUBLIC_*)
# Deploy (Vercel): yes
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
NEXT_PUBLIC_APP_URL=https://your-app-domain.example.com
NEXT_PUBLIC_PRACTICE_STREAM=false
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_REPLACE_ME

# -----------------------------------------------------------------------------
# 2) Supabase + Database (server-only)
# Deploy (Vercel): yes
# -----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME
# Use Supabase transaction pooler URI (:6543) with pgbouncer=true.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true
# Pool size per Node process. Start low in serverless.
DATABASE_POOL_MAX=1

# Optional dedicated rate-limit DB pool (falls back to DATABASE_URL when unset).
# Deploy (Vercel): optional
# DATABASE_RATELIMIT_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true
# DATABASE_RATELIMIT_POOL_MAX=3

# -----------------------------------------------------------------------------
# 3) Email / notifications
# Deploy (Vercel): yes
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_REPLACE_ME
RESEND_FROM_EMAIL="ExamPrep AI <noreply@example.com>"
EMAIL_UNSUBSCRIBE_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET

# -----------------------------------------------------------------------------
# 4) OpenAI models
# Deploy (Vercel): yes
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-REPLACE_ME
OPENAI_CHAT_MODEL=gpt-5.4-mini
OPENAI_DOUBT_CHAT_MODEL=gpt-5.4-mini
OPENAI_PRACTICE_CHAT_MODEL=gpt-5.4-mini
OPENAI_CHAT_MODEL_FALLBACK=gpt-5.4-mini

# -----------------------------------------------------------------------------
# 5) Practice generation + visuals
# Deploy (Vercel): yes
# -----------------------------------------------------------------------------
# Core visuals switches
PRACTICE_VISUALS=true
PRACTICE_VISUAL_TEMPLATE_ENGINE=false
PRACTICE_VISUAL_ENRICHMENT=true
# 1..6 (recommended 2 in prod, 3 for higher visual coverage)
PRACTICE_VISUAL_ENRICHMENT_BATCH_SIZE=2
# off | shadow | enforce (recommended rollout: shadow -> enforce)
PRACTICE_VISUAL_STEM_GROUNDING=shadow
PRACTICE_VISUAL_VALIDATOR=true
PRACTICE_VISUAL_VALIDATOR_MODEL=gpt-5.4-mini
PRACTICE_VISUALS_EVAL_THRESHOLD=0.9
PRACTICE_CHUNK_ALIGN_LEXICAL=true
PRACTICE_VISUAL_EXEMPLAR_COUNT=12

# Legacy knobs currently present in local/prod. Keep only if intentionally used.
PRACTICE_VISUALS_MAX_FRACTION=0.5
PRACTICE_VISUALS_MAX_ABS=12

# Generation/behavior toggles
PRACTICE_SYNC_GRADING=false
PRACTICE_STREAM=false
PRACTICE_ADAPTIVE=true
PRACTICE_DEDUP_MAX_REGENS=1
PRACTICE_PROMPT_PREVIEW=false

# Topic context and dedup controls
PRACTICE_TOPIC_CONTEXT_LOG=true
PRACTICE_DUPLICATE_COSINE_THRESHOLD=90
PRACTICE_TOPIC_CONTEXT_MAX_CONTEXT_CHUNKS_PER_TOPIC=33
PRACTICE_TOPIC_CONTEXT_MAX_EXERCISE_CHUNKS_PER_TOPIC=28
PRACTICE_TOPIC_CONTEXT_MAX_CONTEXT_CHARS_PER_TOPIC=25000
PRACTICE_TOPIC_CONTEXT_MAX_EXERCISE_CHARS_PER_TOPIC=13200
PRACTICE_TOPIC_CONTEXT_MAX_TOTAL_CONTEXT_CHARS=100000
PRACTICE_TOPIC_CONTEXT_MAX_TOTAL_EXERCISE_CHARS=80000

# -----------------------------------------------------------------------------
# 6) Internal route protection + operations
# Deploy (Vercel): yes
# -----------------------------------------------------------------------------
CRON_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
SAAS_ENFORCEMENT=false
MAINTENANCE_MODE=false

# -----------------------------------------------------------------------------
# 7) Observability
# Deploy (Vercel): yes
# -----------------------------------------------------------------------------
SENTRY_DSN=

# -----------------------------------------------------------------------------
# 8) Admin panel auth
# Deploy (Vercel): yes (with production-safe values)
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@example.com

# Local/dev convenience only; DO NOT use in production.
# In production prefer ADMIN_PASSWORD_HASH_B64.
ADMIN_PASSWORD=CHANGE_ME_LOCAL_ONLY

# Production preferred auth secret (bcrypt hash encoded as base64).
# If set, it takes precedence over ADMIN_PASSWORD.
# ADMIN_PASSWORD_HASH_B64=REPLACE_ME

ADMIN_JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
ADMIN_TOTP_SECRET=REPLACE_ME_BASE32
ADMIN_PANIC_TOKEN=REPLACE_WITH_RANDOM_TOKEN
ADMIN_IP_ALLOWLIST=
ADMIN_INTEGRATION_TESTS=false

# -----------------------------------------------------------------------------
# 9) Payments (Razorpay)
# Deploy (Vercel): yes
# -----------------------------------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_REPLACE_ME
RAZORPAY_KEY_SECRET=REPLACE_ME
RAZORPAY_WEBHOOK_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET

# -----------------------------------------------------------------------------
# 10) Local test automation (Playwright)
# Deploy (Vercel): no
# -----------------------------------------------------------------------------
PLAYWRIGHT_BASE_URL=http://localhost:3001
PLAYWRIGHT_ADMIN_EMAIL=admin@example.com
PLAYWRIGHT_ADMIN_PASSWORD=CHANGE_ME_LOCAL_ONLY
PLAYWRIGHT_E2E_TARGET_USER_ID=00000000-0000-0000-0000-000000000000
PLAYWRIGHT_USER_EMAIL=user@example.com
PLAYWRIGHT_USER_PASSWORD=CHANGE_ME_LOCAL_ONLY
