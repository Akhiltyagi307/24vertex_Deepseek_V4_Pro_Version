{
  "name": "examprep-ai-webapp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "node scripts/next-dev.mjs",
    "dev:webpack": "NEXT_DEV_WEBPACK=1 node scripts/next-dev.mjs",
    "dev:pm2": "pnpm exec pm2 start ecosystem.config.cjs --update-env",
    "dev:pm2:stop": "pnpm exec pm2 delete edu-ai-dev",
    "dev:pm2:restart": "pnpm exec pm2 restart edu-ai-dev",
    "dev:pm2:logs": "pnpm exec pm2 logs edu-ai-dev",
    "dev:pm2:clean": "(pnpm exec pm2 delete edu-ai-dev || true) && node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && pnpm run dev:pm2 && node scripts/wait-for-dev-server.mjs",
    "dev:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && node scripts/next-dev.mjs",
    "build": "next build",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint --max-warnings=0 --cache --cache-location node_modules/.cache/eslint/",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:student": "playwright test tests/e2e/auth.setup.ts tests/e2e/smoke.spec.ts tests/e2e/post-login.spec.ts tests/e2e/playwright-env.spec.ts",
    "test:e2e:student:local": "PLAYWRIGHT_START_WEBSERVER=1 pnpm run test:e2e:student",
    "test:e2e:practice:local": "NODE_OPTIONS=\"--require dotenv/config\" DOTENV_CONFIG_PATH=.env.local PLAYWRIGHT_START_WEBSERVER=1 playwright test tests/e2e/practice-full-subjects.spec.ts --project=student",
    "test:e2e:practice:smoke": "PLAYWRIGHT_PRACTICE_E2E_SUBJECT_CAP=1 NODE_OPTIONS=\"--require dotenv/config\" DOTENV_CONFIG_PATH=.env.local PLAYWRIGHT_START_WEBSERVER=1 playwright test tests/e2e/practice-full-subjects.spec.ts --project=student",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "perf:check": "node scripts/perf-check.mjs",
    "bundle:budget": "node scripts/bundle-budget.mjs",
    "deadcode": "knip --reporter compact --include files,dependencies",
    "deadcode:strict": "knip --reporter compact --no-progress --include files,exports,types,duplicates,dependencies",
    "preview:emails": "NODE_OPTIONS=\"--require ./scripts/_preview-cjs-loader.cjs\" tsx scripts/preview-emails.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:repair-profile-prefs": "node scripts/repair-drifted-profile-prefs.mjs",
    "db:repair-profiles-pdr": "node scripts/repair-profiles-pdr-columns.mjs",
    "db:reconcile-migration-ledger": "node -r dotenv/config scripts/reconcile-supabase-migration-ledger.mjs dotenv_config_path=.env.local",
    "db:apply:admin-phase2": "node scripts/apply-admin-phase2-migrations.mjs",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "razorpay:seed-plans": "node scripts/seed-razorpay-plans.mjs",
    "admin:security-phase6": "node scripts/admin-security-phase6.mjs",
    "admin:password-hash-b64": "node scripts/admin-password-hash-b64.mjs",
    "admin:totp-secret": "node scripts/admin-totp-secret.mjs"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.53",
    "@ai-sdk/react": "^3.0.170",
    "@base-ui/react": "^1.3.0",
    "@monaco-editor/react": "^4.7.0",
    "@napi-rs/canvas": "^1.0.0",
    "@next/bundle-analyzer": "^16.2.4",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@react-pdf/renderer": "^4.4.1",
    "@sentry/nextjs": "^10.48.0",
    "@supabase/auth-js": "^2.102.0",
    "@supabase/functions-js": "^2.102.0",
    "@supabase/postgrest-js": "^2.102.0",
    "@supabase/realtime-js": "^2.102.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/storage-js": "^2.102.0",
    "@supabase/supabase-js": "^2.102.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "@tiptap/core": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
