    "@tiptap/extension-subscript": "^3.22.4",
    "@tiptap/extension-superscript": "^3.22.4",
    "@tiptap/extension-table": "^3.22.4",
    "@tiptap/extension-table-cell": "^3.22.4",
    "@tiptap/extension-table-header": "^3.22.4",
    "@tiptap/extension-table-row": "^3.22.4",
    "@tiptap/extension-underline": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@types/archiver": "^7.0.0",
    "@upstash/redis": "^1.36.0",
    "ai": "^6.0.168",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.1",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "function-plot": "^1.25.4",
    "jose": "^6.2.3",
    "katex": "^0.16.45",
    "lucide-react": "^1.7.0",
    "mafs": "^0.21.0",
    "mermaid": "^11.14.0",
    "mjml": "^4.15.3",
    "monaco-editor": "^0.52.2",
    "motion": "^12.38.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "otplib": "^13.4.0",
    "papaparse": "^5.5.3",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^4.10.38",
    "plotly.js-dist-min": "^3.5.1",
    "postgres": "^3.4.9",
    "razorpay": "^2.9.6",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "react-easy-crop": "^5.5.7",
    "react-markdown": "^10.1.0",
    "recharts": "3.8.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "resend": "^6.10.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.2.0",
    "smiles-drawer": "^2.3.0",
    "sonner": "^2.0.7",
    "svix": "1.88.0",
    "tailwind-merge": "^3.5.0",
    "tesseract.js": "^5.1.1",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0",
    "web-vitals": "^5.2.0",
    "zod": "^3.25.76"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.25.0",
      "hono": "^4.12.14",
      "postcss": "^8.5.10",
      "uuid": "^11.0.0"
    },
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "esbuild",
      "msw",
      "sharp",
      "tesseract.js",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.0",
    "@vitest/coverage-v8": "^4.1.5",
    "axe-core": "^4.11.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "jsdom": "^26.1.0",
    "knip": "^5.78.0",
    "pm2": "^6.0.14",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.3"
  }
}
