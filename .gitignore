# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
# (no trailing slash so symlinks named `node_modules` are also ignored —
# git was tracking such a symlink in this worktree, breaking CI installs)
node_modules
/.pnp
.pnp.js

# Next.js
.next/

# Build / export output
out/
build/
dist/

# Testing
coverage/
/test-results/
/playwright-report/
/blob-report/
.playwright-cache/

# Playwright auth storage (local secrets — never commit)
playwright/.auth/

# Env (local secrets — never commit)
.env
.env*.local
env.local

# pnpm store when created inside the repo (never commit)
.pnpm-store/

# Supabase CLI local cache (e.g. version pins); not part of migrations
supabase/.temp/

# Ad-hoc topic sync tooling output (local only)
.topic-sync-out/
.topic-sync-chunks/
.topic-sync-work/
.cursor-topic-sync-*.sql
.topic-sync-chunk.sql
.topic-sync-upsert-*.sql
.topic-sync-mcp-arg-*.json
mcp-payload-*.json

# TypeScript / tooling caches
*.tsbuildinfo
.eslintcache

# Debug / OS
.DS_Store
Thumbs.db
*.pem
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Vercel (linked project metadata — local only)
.vercel/

# Local dev logs (do not commit)
.cursor-dev-server.log
dev-nohup.log
*.log

# Temp / scratch
tw-debug.css
.tmp/
.tmp_*.json
.mcp-github-push-batches/
.mcp-batch-args/
