*.tsbuildinfo
.eslintcache

# Debug / OS
.DS_Store
Thumbs.db
*.pem
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Vercel (linked project metadata — local only)
.vercel/

