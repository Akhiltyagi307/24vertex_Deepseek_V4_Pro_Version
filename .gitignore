# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
# (no trailing slash so symlinks named `node_modules` are also ignored —
# git was tracking such a symlink in this worktree, breaking CI installs)
node_modules
/.pnp
.pnp.js

# Next.js
.next/

# Build / export output
out/
build/
dist/

# Testing
coverage/
/test-results/
/playwright-report/
/blob-report/
.playwright-cache/

# Playwright auth storage (local secrets — never commit)
playwright/.auth/

# Env (local secrets — never commit)
.env
.env*.local
env.local

# pnpm store when created inside the repo (never commit)
.pnpm-store/

# Supabase CLI local cache (e.g. version pins); not part of migrations
supabase/.temp/

# TypeScript / tooling caches
*.tsbuildinfo
.eslintcache

# Debug / OS
.DS_Store
Thumbs.db
*.pem
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Vercel (linked project metadata — local only)
.vercel/

# Local dev logs (do not commit)
.cursor-dev-server.log
dev-nohup.log
*.log

# Temp / scratch
tw-debug.css
.tmp_*.json
.mcp-github-push-batches/

# Local-only email preview output (generated by scripts/preview-emails.ts)
/artifacts/email-previews/

# IDE (optional; remove if your team commits shared IDE config)
.idea/

# Agent / assistant metadata (non-app source)
.agents/
.cursor/
.claude/

# TestSprite generated suites (local tooling output)
testsprite_tests/

# Product / design markdown (kept local; not versioned in this repo).
# Exception: doubt-chat prompt templates are loaded at runtime by
# src/lib/ai/doubt-prompt-templates.ts and must ship with the deploy.
# Exception: billing/* operational runbooks are committed so on-call has
# them when responding to billing incidents.
# Exception: practice/* operational runbooks are committed for the same
# on-call reason (visuals rollout / rollback).
docs/*
!docs/explain-mode-prompt.md
!docs/solve-with-me-mode-prompt.md
!docs/billing/
!docs/billing/*.md
!docs/practice/
!docs/practice/*.md

# One-off local notes at repo root (keep out of git)
EduAI_PRD_v3_2_TestSprite_Backend.md
